{
  "name": "verify-hydra",
  "version": "1.0.0",
  "private": true,
  "description": "Open source Discord verification system with Cloudflare Workers and Supabase",
  "scripts": {
    "bot:install": "cd bot && npm install",
    "bot:start": "cd bot && npm start",
    "bot:dev": "cd bot && npm run dev",
    "worker:install": "cd worker && npm install",
    "worker:deploy": "cd worker && npx wrangler deploy",
    "db:migrate": "echo 'Run database/schema.sql in Supabase SQL Editor'"
  },
  "keywords": ["discord", "verification", "captcha", "cloudflare-workers", "supabase", "open-source"],
  "license": "MIT"
}
